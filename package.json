{
  "name": "next.js-heroui-v2-template",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "scripts": {
    "prepare": "husky",
    "dev": "next dev --turbopack",
    "build": "next build",
    "build-win": "next build && npm run move-win",
    "build-linux": "next build && npm run move-linux",
    "start": "next start",
    "start-alone": "node .next/standalone/server.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "move-win": "xcopy /e /i .next\\static .next\\standalone\\.next\\static && xcopy /e /i public\\icons .next\\standalone\\public\\icons",
    "move-linux": "rm -rf standalone && mkdir -p standalone/.next && cp -r .next/standalone/* standalone/ && cp -r .next/static standalone/.next/static && cp -r public/icons standalone/public/icons && cp package.json standalone/ && cp .env.production standalone/ || true"
  },
  "dependencies": {
    "@heroui/react": "2.8.10",
    "@heroui/theme": "2.4.26",
    "@react-aria/ssr": "^3.10.0",
    "@react-aria/visually-hidden": "3.8.31",
    "clsx": "2.1.1",
    "cookies-next": "^6.1.1",
    "framer-motion": "11.18.2",
    "gsap": "^3.15.0",
    "intl-messageformat": "10.7.16",
    "motion": "^12.38.0",
    "next": "15.5.9",
    "next-themes": "0.4.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "simplex-noise": "^4.0.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/compat": "1.2.8",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.25.1",
    "@iconify/react": "^6.0.2",
    "@next/eslint-plugin-next": "^15.5.15",
    "@tailwindcss/postcss": "4.1.11",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "20.5.7",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "8.34.1",
    "@typescript-eslint/parser": "8.34.1",
    "eslint": "9.25.1",
    "eslint-config-prettier": "10.1.5",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.5.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-unused-imports": "4.1.4",
    "globals": "16.0.0",
    "husky": "9.1.7",
    "postcss": "8.5.6",
    "prettier": "3.5.3",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.1.11",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@heroui/shared-utils",
      "@tailwindcss/oxide",
      "sharp",
      "unrs-resolver"
    ]
  }
}
